# SERVER
PORT=3001
NODE_ENV=development

# DATABASE
DATABASE_URL=postgresql://appuser:password@localhost:5432/bookingplatform

# REDIS
REDIS_URL=redis://localhost:6379

# CLERK AUTHENTICATION
# Get from clerk.com → Your App → API Keys
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# META WHATSAPP API
# Get from developers.facebook.com
META_WHATSAPP_TOKEN=your_meta_whatsapp_token
META_WEBHOOK_VERIFY_TOKEN=any_random_secret_string
META_PHONE_NUMBER_ID=your_phone_number_id

# GEMINI AI
# Get your API key from: aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_from_aistudio

# WAHA (development only)
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=your_waha_api_key

# SUPER ADMIN
# Comma separated Clerk user IDs for platform owners
# Get your Clerk user ID after signing up at clerk.com
SUPER_ADMIN_IDS=

# DEVELOPMENT BYPASS
# true = skip Clerk auth, use x-dev-role headers
# false = require real Clerk JWT tokens
# ALWAYS set to false in production
BYPASS_AUTH=true
